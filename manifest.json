{
  "manifest_version": 3,
  "name": "Netflix Movie Clipper",
  "version": "1.0.0",
  "description": "Movie clipping 001",

  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting" 
  ],

  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://www.netflix.com/*",
    "https://www.disneyplus.com/*"
  ],

  "background": {
    "service_worker": "src/background/background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.netflix.com/*"],
      "run_at": "document_end",
      "js": ["src/inject/inject_script.js",
             "src/util/history_change.js"]
    },
    {
      "matches": ["https://www.netflix.com/*"],
      "run_at": "document_idle",
      "js": ["dist/content.js"]
    },
    {
      "matches": ["https://www.disneyplus.com/*"],
      "run_at": "document_idle",
      "js": ["dist/content_disney.js"]
    },
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "run_at": "document_idle",
      "js": ["dist/extension_link.js", "src/content/getClipData.js"]
    }
  ],

  "web_accessible_resources": [
    {
      "matches": ["https://www.netflix.com/*"],
      "resources": ["src/util/history_change.js"]
    }
  ]
}
